# ==============================================================================
# 🏠 GLOBAL HOMELAB CONFIGURATION (Single Source of Truth)
# ==============================================================================
# Instructions: 
# 1. Copy this file to .env: `cp .env.example .env`
# 2. Fill in your secrets below.
# 3. Use `source .env` before running Terraform or Ansible.
# ==========================================================

# --- Proxmox API (Terraform) ---
# See docs/PREREQUISITES.md #2 for token generation.
TF_VAR_proxmox_host="10.3.0.5"
TF_VAR_pm_api_token_id="terraform-user@pve!prov-token"
TF_VAR_pm_api_token_secret="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
TF_VAR_pm_api_url="https://10.3.0.5:8006/api2/json"
TF_VAR_target_node="pve"
TF_VAR_storage_id="local-lvm"

# --- Network & Domain ---
DOMAIN="j1103.in"
ACME_EMAIL="admin@j1103.in"
# Set to 'staging' for testing to avoid rate limits!
# Options: 'production', 'staging'
LETSENCRYPT_ENV="staging"

# --- Production Environment Specs ---
PROD_PVE_IP="10.3.0.5"
PROD_NETWORK_PREFIX="10.3.1"
PROD_GATEWAY="10.3.0.1"

# --- Development Environment Specs ---
# Used when running with `-i ansible/inventories/dev`
DEV_PVE_IP="10.3.0.11"
DEV_NETWORK_PREFIX="10.3.99"
DEV_GATEWAY="10.3.0.1"

# --- Ansible Vault ---
# Used to encrypt inventory secrets.
ANSIBLE_VAULT_PASSWORD_FILE="./.vault_pass"

# --- Cloud Backup (Rclone + Google Drive) ---
# See docs/PREREQUISITES.md #5 for generating these.
RCLONE_CONFIG_GDRIVE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
RCLONE_CONFIG_GDRIVE_CLIENT_SECRET="your-client-secret"

# This token is a JSON string generated by rclone.
# Use single quotes to avoid shell escaping issues.
RCLONE_CONFIG_GDRIVE_TOKEN='{"access_token":"xxx","token_type":"Bearer","refresh_token":"xxx","expiry":"2026-02-28T..."}'

# --- Hardware Customization ---
# IDs for physical disks (run `ls -l /dev/disk/by-id/` on Proxmox)
MEDIA_DISK_ID="/dev/disk/by-id/ata-YOUR_8TB_DISK_SERIAL"
BACKUP_DISK_ID="/dev/disk/by-id/ata-YOUR_4TB_DISK_SERIAL"
