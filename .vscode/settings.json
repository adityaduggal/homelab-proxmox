{
  "yaml.schemas": {
    "https://json.schemastore.org/ansible-playbook.json": "ansible/playbooks/*.yml",
    "https://json.schemastore.org/ansible-inventory.json": "ansible/inventories/**/*.yml"
  },
  "yaml.format.enable": true,
  "editor.formatOnSave": true,
  "ansible.ansible.path": "ansible",
  "terraform.languageServer.external": true,
  "files.associations": {
    "*.tf": "terraform",
    "*.tfvars": "terraform"
  }
}
